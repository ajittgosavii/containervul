# ==============================================================================
# Enterprise Container Vulnerability Management — Environment Variables
# ==============================================================================
# Copy to .env and fill in your values.

# ── AI Configuration ─────────────────────────────────────────────────────────
CONTAINERVUL_CLAUDE_API_KEY=your-anthropic-api-key
CONTAINERVUL_CLAUDE_MODEL=claude-sonnet-4-20250514

# ── AWS Configuration ────────────────────────────────────────────────────────
# AWS_PROFILE=default
# AWS_DEFAULT_REGION=us-east-1
# Or set explicitly:
# CONTAINERVUL_AWS_ACCESS_KEY_ID=
# CONTAINERVUL_AWS_SECRET_ACCESS_KEY=

# ── Azure Configuration ──────────────────────────────────────────────────────
# CONTAINERVUL_AZURE_TENANT_ID=
# CONTAINERVUL_AZURE_CLIENT_ID=
# CONTAINERVUL_AZURE_CLIENT_SECRET=

# ── GCP Configuration ────────────────────────────────────────────────────────
# CONTAINERVUL_GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── ServiceNow Configuration ─────────────────────────────────────────────────
# CONTAINERVUL_SERVICENOW_INSTANCE=https://devXXXXX.service-now.com
# CONTAINERVUL_SERVICENOW_USERNAME=admin
# CONTAINERVUL_SERVICENOW_PASSWORD=your-password
# CONTAINERVUL_SERVICENOW_AUTH_METHOD=basic
# CONTAINERVUL_SERVICENOW_AUTO_CREATE_THRESHOLD=HIGH
# CONTAINERVUL_SERVICENOW_DEFAULT_ASSIGNMENT_GROUP=Container Security
# CONTAINERVUL_SERVICENOW_CMDB_SYNC_ENABLED=false
# CONTAINERVUL_SERVICENOW_BIDIRECTIONAL_SYNC=false

# ── Storage ──────────────────────────────────────────────────────────────────
CONTAINERVUL_STORAGE_BACKEND=session
# CONTAINERVUL_SQLITE_PATH=containervul.db

# ── MCP Server ───────────────────────────────────────────────────────────────
CONTAINERVUL_MCP_TRANSPORT=stdio
CONTAINERVUL_MCP_PORT=8100
